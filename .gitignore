[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio cache/options
.vs/
.vscode/
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files
*.rsuser

# Build results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NuGet Packages
*.nupkg
*.snupkg
**/packages/*
!**/packages/build/

# Visual Studio profiler
*.psess
*.vsp
*.vspx
*.sap

# ReSharper
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# TeamCity
_TeamCity*

# DotCover
*.dotCover

# NCrunch
_NCrunch_*
.*crunch*.local.xml
nCrunchTemp_*

# Publish files
[Pp]ublish/

# Windows thumbnail cache
Thumbs.db
ehthumbs.db

# macOS
.DS_Store

# Rider
.idea/
*.sln.iml

# Local configuration
*.local.json
appsettings.*.json
!appsettings.Development.json

# Claude Code
.claude/
CLAUDE.md

# Build outputs (只在 Release 中发布，不提交到 Git)
*.exe
!OpenSteamKitten/bin/**/*.exe

# 发布产物（统一输出目录 dist/，绝不散落根目录）
dist/
/OpenSteamKitten-*.zip
