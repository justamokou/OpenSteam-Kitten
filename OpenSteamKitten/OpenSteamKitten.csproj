<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net6.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <AssemblyName>OpenSteamKitten</AssemblyName>
    <RootNamespace>OpenSteamKitten</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <None Include="Resources\dlls\**\*" CopyToOutputDirectory="PreserveNewest" />
    <None Include="..\VERSION" CopyToOutputDirectory="PreserveNewest" Link="VERSION" />
  </ItemGroup>

</Project>
