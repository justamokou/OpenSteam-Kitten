<Window x:Class="OpenSteamKitten.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OpenSteam Kitten"
        Width="80" Height="80"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        AllowDrop="True"
        MouseDown="Window_MouseDown"
        MouseDoubleClick="Window_MouseDoubleClick"
        Drop="Window_Drop"
        DragEnter="Window_DragEnter"
        DragOver="Window_DragOver"
        Loaded="Window_Loaded"
        Closing="Window_Closing">

    <Grid>
        <!-- 圆形悬浮窗背景 -->
        <Ellipse x:Name="BackgroundEllipse" Fill="#FF1A1A1A" Stroke="#FF404040" StrokeThickness="2"/>

        <!-- 文字图标 -->
        <Viewbox Width="50" Height="50">
            <TextBlock Text="🐱" FontSize="40" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Viewbox>

        <!-- 右键菜单 -->
        <Grid.ContextMenu>
            <ContextMenu Opened="ContextMenu_Opened">
                <MenuItem Header="一键安装 DLL 📦" Click="InstallDlls_Click" FontWeight="Bold"/>
                <MenuItem Header="一键清理 🧹">
                    <MenuItem Header="清理内核 DLL" Click="CleanDlls_Click"/>
                    <MenuItem Header="清理 Lua 配置" Click="CleanLua_Click"/>
                    <MenuItem Header="清理清单文件" Click="CleanManifests_Click"/>
                </MenuItem>
                <MenuItem Header="打开 Lua 目录 📁" Click="OpenLuaFolder_Click"/>
                <Separator/>
                <MenuItem Header="打开 Steam 🎮" Click="OpenSteam_Click"/>
                <MenuItem Header="重启 Steam ♻️" Click="RestartSteam_Click"/>
                <Separator/>
                <MenuItem x:Name="SteamLaunchMenuItem" Header="随 Steam 启动 🚀" IsCheckable="True" Click="SteamLaunch_Click"/>
                <MenuItem x:Name="HideInGameMenuItem" Header="Steam 游戏时隐藏悬浮窗 🎮" IsCheckable="True" Click="HideInGame_Click"/>
                <MenuItem Header="隐藏悬浮窗 👁" Click="HideFloatingWindow_Click"/>
                <MenuItem Header="检查更新 🔄" Click="CheckUpdate_Click"/>
                <MenuItem Header="关于" Click="About_Click"/>
                <MenuItem Header="退出 ❌" Click="Exit_Click"/>
            </ContextMenu>
        </Grid.ContextMenu>
    </Grid>
</Window>
